# ── Frontend (Vite) ───────────────────────────────────────────
# Só a URL e a chave PÚBLICA do Supabase ficam aqui. NENHUMA chave secreta.
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx

# ── Secrets das Edge Functions (NÃO vão no .env do front!) ─────
