# ── Frontend (Vite) ───────────────────────────────────────────
# Só a URL e a chave PÚBLICA do Supabase ficam aqui. NENHUMA chave secreta.
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx

# ── Secrets das Edge Functions (NÃO vão no .env do front!) ─────
# Configure no Supabase com:  supabase secrets set NOME=valor
#
#   OPENAI_API_KEY=sk-...               (conversação + chat de dúvidas)
#   OPENAI_MODEL=gpt-4o-mini            (opcional)
#   AZURE_SPEECH_KEY=...                (pronúncia)
#   AZURE_SPEECH_REGION=westeurope      (pronúncia)
#   YOUTUBE_API_KEY=...                 (vídeo do dia)
